{
    "name": "dereuromark/cakephp-fixture-factories",
    "description": "A CakePHP plugin for creating test fixtures dynamically with factory pattern",
    "type": "cakephp-plugin",
    "keywords": ["cakephp", "tests", "dynamic", "fixtures", "dev", "cli", "testing", "factories", "faker"],
    "homepage": "https://github.com/dereuromark/cakephp-fixture-factories",
    "support": {
        "source": "https://github.com/dereuromark/cakephp-fixture-factories"
    },
    "authors": [
        {
            "name": "Mark Scherer",
            "email": "euromark@web.de"
        },
        {
            "name": "Nicolas Masson",
            "email": "nicolas@b-projects.tech"
        },
        {
            "name": "Juan Pablo Ramìrez",
            "email": "pabloelcolombiano@gmail.com"
        },
        {
            "name": "Jamison Bryant",
            "email": "jamison@bryant.ai"
        }
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "cakephp/orm": "^5.0"
    },
    "require-dev": {
        "cakephp/bake": "^3.0.0",
        "cakephp/migrations": "^4.7.0 || ^5.0.0",
        "cakephp/twig-view": "^2.0.2",
        "dereuromark/cakephp-ide-helper": "^2.17",
        "fakerphp/faker": "^1.23",
        "johnykvsky/dummygenerator": "^0.2.1",
        "josegonzalez/dotenv": "^4.0.0",
        "php-collective/code-sniffer": "dev-master",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5 || ^12.1 || ^13.0",
        "rector/rector": "^2.1",
        "vierge-noire/cakephp-test-suite-light": "^3.0"
    },
    "suggest": {
        "dereuromark/cakephp-ide-helper": "Lets `bin/cake annotate classes` (and `annotate all`) keep your Factory subclass docblocks in sync via the bundled FactoryAnnotatorTask. Requires version with PathAwareClassAnnotatorTaskInterface support."
    },
    "autoload": {
        "psr-4": {
            "CakephpFixtureFactories\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CakephpFixtureFactories\\Test\\": "tests/",
            "TestApp\\": "tests/TestApp/src/",
            "TestApp\\Test\\Factory\\": "tests/TestApp/tests/Factory/",
            "TestPlugin\\": "tests/TestApp/plugins/TestPlugin/src/",
            "TestPlugin\\Test\\Factory\\": "tests/TestApp/plugins/TestPlugin/tests/Factory/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "mysql": "bash run_tests.sh Mysql \"$@\"",
        "pgsql": "bash run_tests.sh Postgres \"$@\"",
        "sqlite": "bash run_tests.sh Sqlite \"$@\"",
        "rector": "rector process --config rector.php",
        "rector-dry-run": "rector process --dry-run --config rector.php",
        "stan": "phpstan analyze --memory-limit=-1",
        "cs-check": "phpcs --colors --parallel=16",
        "cs-fix": "phpcbf --colors --parallel=16"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
